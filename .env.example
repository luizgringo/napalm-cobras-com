# URL pública do site (canonical/OG/sitemap). Em produção: https://www.napalmcobras.com
NEXT_PUBLIC_SITE_URL="https://www.napalmcobras.com"

# Integrações — Tier 2 (opcionais). Sem estas, o site usa embeds/links (Tier 1).

# Bandsintown — agenda nativa via API. ID público do app (não é segredo).
NEXT_PUBLIC_BANDSINTOWN_APP_ID=""

# Spotify Web API (Client Credentials) — dados de álbum/artista.
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Instagram — feed automático via Behold.so (alternativa à Graph API).
BEHOLD_FEED_ID=""
